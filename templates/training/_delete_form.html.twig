<form method="post" action="{{ path('training_delete', {'id': training.id}) }}"
   onsubmit="return confirm(`Confirmez-vous la suppression définitive de cette séance d'entrainnement`);" 
    class="flex items-center">
    
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ training.id) }}">
    
    <button type="submit" 
            class="text-[10px] font-black uppercase tracking-widest text-red-500 hover:text-red-700 active:scale-95 transition-all">
        Supprimer
    </button>
</form>