<form method="post" action="{{ path('training_delete', {'id': training.id}) }}"
   onsubmit="return confirm(`Confirmez-vous la suppression définitive de cette séance d'entrainnement`);" 
    class="flex items-center">
    
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ training.id) }}">
    
    <button type="submit" 
            class="flex-1 text-[9px] text-center px-2 py-2 border-2 border-slate-900 bg-red-500 font-black uppercase tracking-widest text-white hover:bg-red-500 hover:text-white active:scale-95 transition-all">
        Supprimer
    </button>
</form>