{% extends 'base.html.twig' %}

{% block title %}Les entraînements{% endblock %}

{% block body %}
<div class="max-w-md mx-auto px-4 mt-6 pb-20">

    <div class="mb-10 text-center">
        <h2 class="text-4xl font-black uppercase tracking-tighter text-slate-900 leading-none">
            Les <span class="text-indigo-600">entraînements</span>
        </h2>

        <div class="flex justify-center mt-6">
            <a href="{{ path('training_new') }}"
                class="bg-slate-900 text-white px-8 py-3 font-black uppercase text-xs tracking-widest active:bg-indigo-600 transition-colors">
                + Créer un entraînement
            </a>
        </div>
    </div>

    <div class="space-y-4">
        {% for training in trainings %}
        <div class="bg-white border-4 border-slate-900 p-4 transition-transform">

            <div class="flex justify-between items-start mb-4">
                <div class="cursor-pointer" data-url="{{ path('training_show', {'id': training.id}) }}"
                    onclick="window.location.href=this.dataset.url">
                    
                    <span class="inline-block bg-indigo-600 text-white text-[10px] font-black px-2 py-0.5 uppercase mb-1">
                        {{ training.date ? training.date|date('d/m/y') : 'À programmer' }}
                    </span>
                    
            
                    {% if training.attendances|length > 0 %}
                        <span class="inline-block bg-emerald-100 text-emerald-700 text-[9px] font-bold px-2 py-0.5 uppercase mb-1 border border-emerald-300">
                            ✓ Appel fait
                        </span>
                    {% else %}
                        <span class="inline-block bg-amber-100 text-amber-700 text-[9px] font-bold px-2 py-0.5 uppercase mb-1 border border-amber-300">
                            ! Appel à faire
                        </span>
                    {% endif %}

                    <p class="text-slate-500 text-xs font-bold uppercase mt-2">
                       Heure : {{ training.startTime ? training.startTime|date('H:i') : '--:--' }} - {{ training.endTime ? training.endTime|date('H:i') : '--:--' }}
                    </p>
                    <p class="text-slate-900 text-sm font-black uppercase mt-1">
                       Thème : {{ training.theme.value }} 
                    </p>
                </div>
            </div>


            <div class="mt-2">
                <a href="{{ path('attendance_take_mass', {'type': 'training', 'id': training.id}) }}" 
                   class="block text-center bg-slate-900 text-white py-2 text-[10px] font-black uppercase tracking-[0.2em] hover:bg-indigo-600 transition-colors border-2 border-slate-900">
                   Faire l'appel 
                </a>
            </div>

            <div class="flex border-t-2 border-slate-900 mt-4 pt-3 gap-4 items-center">
                <a href="{{ path('training_show', {'id': training.id}) }}"
                    class="text-[10px] font-black uppercase tracking-widest text-blue-400 hover:text-indigo-600">Voir</a>
                
                <a href="{{ path('training_update', {'id': training.id}) }}"
                    class="text-[10px] font-black uppercase tracking-widest text-slate-400 hover:text-indigo-600">Modifier</a>
                
                <div class="text-[10px] font-black uppercase tracking-widest text-red-500">
                    {% include "training/_delete_form.html.twig" %}
                </div>
            </div>
        </div>
        {% else %}
            <p class="text-center text-slate-400 font-bold uppercase text-xs">Aucun entraînement prévu.</p>
        {% endfor %}
    </div>

</div>
{% endblock %}