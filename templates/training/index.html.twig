{% extends 'base.html.twig' %}

{% block title %}Planning Entraînements{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto px-4 mt-8 pb-20">

    
    <div class="mb-10 ">
        <h2 class="text-3xl font-black uppercase tracking-tighter text-slate-900 leading-none mb-4">
            Les <span class="text-indigo-600">entraînements</span>
        </h2>
        
        <a href="{{ path('training_new') }}"
            class="inline-block bg-slate-900 text-white px-6 py-3 text-[10px] font-black uppercase tracking-widest border-2 border-slate-900 hover:bg-white hover:text-slate-900 transition-all ">
            + Créer un entraînement
        </a>
    </div>


    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {% for training in trainings %}
        <div class="bg-white border-4 border-slate-900 p-6 flex flex-col justify-between relative overflow-hidden group ]">

            <span class="absolute top-0 left-0 bg-slate-900 text-white text-[9px] font-black px-3 py-1 uppercase tracking-tighter italic">
                {{ training.date ? training.date|date('d/m/Y') : 'À programmer' }}
            </span>

          
            <div class="mb-6 mt-6">
                <div class="flex items-center gap-2 mb-3">
                    {% if training.attendances|length > 0 %}
                        <span class="bg-emerald-500 text-white text-[8px] font-black px-2 py-0.5 uppercase">✓ Appel fait</span>
                    {% else %}
                        <span class="bg-amber-500 text-white text-[8px] font-black px-2 py-0.5 uppercase">! Appel à faire</span>
                    {% endif %}
                </div>

                <h3 class="text-2xl font-black uppercase leading-none mb-2">
                    {{ training.theme.value|default('Entraînement') }}
                </h3>
                
                <p class="text-slate-500 text-[10px] font-bold uppercase tracking-widest italic">
                    HORAIRE : {{ training.startTime ? training.startTime|date('H:i') : '--:--' }} - {{ training.endTime ? training.endTime|date('H:i') : '--:--' }}
                </p>
            </div>

          
            <div class="space-y-2">
               
                <a href="{{ path('attendance_take_mass', {'type': 'training', 'id': training.id}) }}" 
                   class="block text-center bg-emerald-500 text-white py-2 text-[10px] font-black uppercase tracking-widest border-2 border-slate-900 hover:bg-slate-900 transition-colors">
                   Faire l'appel
                </a>

                <div class="flex gap-2 border-t-2 border-slate-900 pt-3">
                 
                    <a href="{{ path('training_show', {id: training.id}) }}"
                        class="flex-1 text-center text-[9px] font-black uppercase tracking-widest bg-slate-900 text-white px-2 py-2 hover:bg-indigo-600 transition-colors">
                        Voir
                    </a>

                    <a href="{{ path('training_update', {id: training.id}) }}"
                        class="flex-1 text-center text-[9px] font-black uppercase tracking-widest border-2 border-slate-900 px-2 py-2 hover:bg-slate-900 hover:text-white transition-all">
                        Modifier
                    </a>

                   
                    {% include "training/_delete_form.html.twig" %}
                </div>
            </div>
        </div>
        {% else %}
        <div class="col-span-full py-16 text-center border-4 border-dashed border-slate-200 bg-slate-50">
            <p class="text-slate-400 font-black uppercase tracking-widest">Aucun entraînement programmé</p>
        </div>
        {% endfor %}
    </div>
</div>
{% endblock %}