{% extends 'base.html.twig' %}

{% block title %}Détails de l'entraînement {% endblock %}

{% block body %}
<div class="max-w-xl mx-auto px-4 mt-6 pb-20">
 
    <div class="mb-8">
        <h2 class="text-3xl font-black uppercase tracking-tighter text-slate-900 leading-none">
             {% if training.date|date('d/m/y') %}
               Date de l'entraînement {{ training.date|date('d/m/y') }}
                {% else %}
                À programmer
                {% endif %}
        </h2>

    </div>

    <div class="space-y-6">
    
        <div class="bg-white border-2 border-slate-900 p-6">
            <h3 class="text-xs font-black uppercase text-slate-400 mb-4 tracking-widest">Informations sur l'entraînement</h3>
            
            <div class="space-y-4">
                {% if training.theme.name %}
                <div class="flex justify-between items-center pt-2 border-t border-slate-100">
                    <div>
                        <span class="block text-xs font-bold uppercase text-slate-500">Théme de l'entraînement : <span class="text-lg font-bold">{{training.theme.value }}</span></span>
    
                    </div>
                </div>
                {% endif %}
               
                {% if training.startTime|date("H:i") %}
                <div class="flex justify-between items-center pt-2 border-t border-slate-100">
                    <div>
                        <span class="block text-xs font-bold uppercase text-slate-500">Heure de début : <span class="text-lg font-bold">{{training.startTime|date('H:i')  }}</span></span>
    
                    </div>
                </div>
                {% endif %}

                {% if training.endTime|date("H:i") %}
                <div class="pt-2 border-t border-slate-100">
                    <span class="block text-xs font-bold uppercase text-slate-500">Heure de fin : <span class="text-lg font-bold break-all">{{ training.endTime|date('H:i') }}</span> </span>
                    
                </div>
                {% endif %}
                {% if training.coachObservation %}
                <div class="pt-2 border-t border-slate-100">
                    <span class="block text-xs font-bold uppercase text-slate-500">Commentaires</span>
                    <p class="text-xs font-bold break-all">{{ training.coachObservation }}</p>
                </div>
                {% endif %}

            </div>
        </div>

        <div class="grid grid-cols-2 gap-4 mt-8">
            <a href="{{ path('training_update', {'id': training.id}) }}" class="bg-white text-slate-900 text-center py-4 border-2 border-slate-900 font-black uppercase text-sm hover:bg-slate-50 transition-all">
                Modifier
            </a>
            <a href="{{ path('training_index') }}" class="bg-slate-900 text-white text-center py-4 border-2 border-slate-900 font-black uppercase text-sm hover:bg-indigo-600 transition-all">
                Retour
            </a>
        </div>
    </div>
</div>
{% endblock %}