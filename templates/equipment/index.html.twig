


{% extends 'base.html.twig' %}

{% block body %}
<div class="max-w-4xl mx-auto px-4 mt-8 pb-20">
    
    <div class="mb-10">
        <h2 class="text-4xl font-black uppercase tracking-tighter text-slate-900 leading-none mb-4">
            Gestion <span class="text-indigo-600">de l'équipement</span>
        </h2>
        
        <a href="{{ path('equipment_new') }}"
            class="inline-block bg-slate-900 text-white px-6 py-3 text-[10px] font-black uppercase tracking-widest border-2 border-slate-900 hover:bg-white hover:text-slate-900  active:shadow-none transition-all">
            + Créer un équipement
        </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {% for equipment in equipments %}
            {% set currentStock = equipment.currentStock %}
            {% set minStock = equipment.alertLevel|default(0) %}
            {% set isLowStock = currentStock <= minStock %}

            <div class="bg-white border-4 border-slate-900 p-6 flex flex-col justify-between relative overflow-hidden group ">

                <a href="{{ path('equipment_show', {id: equipment.id}) }}"
                        
                    </a>
                <span class="absolute top-0 left-0 bg-slate-900 text-white text-[8px] font-black px-3 py-1 uppercase tracking-tighter italic">
                    {{ equipment.category|default('Général') }}
                </span>

            
                {% if isLowStock %}
                    <span class="absolute top-0 right-0 bg-red-500 text-white text-[8px] font-black px-3 py-1 uppercase animate-pulse">
                        ⚠️ Réapprovisionner
                    </span>
                {% endif %}

                <div class="mb-6 mt-5">
                    <h3 class="text-2xl font-black uppercase leading-none mb-1">{{ equipment.name }}</h3>
                    <p class="text-slate-400 text-[9px] font-bold uppercase tracking-widest italic">REF: #EQ-{{ equipment.id }}</p>
                </div>

              
                <div class="grid grid-cols-2 gap-4 mb-6">
                    <div class="border-2 border-slate-900 p-3 {{ isLowStock ? 'bg-red-50' : 'bg-slate-50' }}">
                        <span class="block text-[8px] font-black uppercase text-slate-500 mb-1">En Stock</span>
                        <span class="text-3xl font-black leading-none {{ isLowStock ? 'text-red-600' : 'text-slate-900' }}">
                            {{ currentStock }}
                        </span>
                    </div>
                    <div class="border-2 border-slate-900 p-3 bg-white">
                        <span class="block text-[8px] font-black uppercase text-slate-500 mb-1">Seuil Min</span>
                        <span class="text-3xl font-black leading-none text-slate-900">
                            {{ minStock }}
                        </span>
                    </div>
                </div>


                <div class="flex flex-wrap gap-2 border-t-2 border-slate-900 pt-4">

                    <a href="{{ path('equipment_update', {id: equipment.id}) }}"
                        class="flex-1 text-center text-[9px] font-black uppercase tracking-widest border-2 border-slate-900 px-2 py-3 hover:bg-slate-900 hover:text-white transition-all">
                        Modifier
                    </a>

                    <a href="{{ path('stock_new', {'id': equipment.id}) }}"
                        class="flex-1 text-center text-[9px] font-black uppercase tracking-widest bg-emerald-500 text-white px-2 py-3 hover:bg-slate-900 transition-colors">
                        + Stock
                    </a>
                    {% include "equipment/_delete_form.html.twig" %}
                    
                    {# <div class="w-full mt-2 sm:w-auto sm:mt-0">
                        
                    </div> #}
                </div>
            </div>
        {% else %}
            <div class="col-span-full py-16 text-center border-4 border-dashed border-slate-200 bg-slate-50">
                <p class="text-slate-400 font-black uppercase tracking-widest">Aucun équipement enregistré</p>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}