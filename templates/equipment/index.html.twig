{% extends 'base.html.twig' %}

{% block body %}
<div class="max-w-4xl mx-auto px-4 mt-8 pb-20">
  
    <div class="mb-10">
        <h2 class="text-4xl font-black uppercase tracking-tighter text-slate-900 leading-none mb-4">
            Gestion <span class="text-indigo-600">de l'équipement</span>
        </h2>
        
     
        <a href="{{ path('equipment_new') }}"
            class="inline-block bg-slate-900 text-white px-6 py-3 text-[10px] font-black uppercase tracking-widest border-2 border-slate-900 hover:bg-white hover:text-slate-900 transition-all ">
            + Créer un article
        </a>
    </div>

   
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {% for equipment in equipments %}
        <div class="bg-white border-4 border-slate-900 p-6 flex flex-col justify-between relative overflow-hidden group ">

            <span class="absolute top-0 left-0 bg-slate-900 text-white text-[8px] font-black px-3 py-1 uppercase tracking-tighter italic">
                {{ equipment.category|default('Général') }}
            </span>

       
            <div class="mb-8 mt-5">
                <h3 class="text-2xl font-black uppercase leading-none mb-1">{{ equipment.name }}</h3>
                <p class="text-slate-400 text-[9px] font-bold uppercase tracking-widest italic">REF: #EQ-{{ equipment.id }}</p>
            </div>

            <div class="flex flex-wrap gap-2 border-t-2 border-slate-900 pt-4">
           
                <a href="{{ path('equipment_show', {id: equipment.id}) }}"
                    class="flex-1 text-center text-[9px] font-black uppercase tracking-widest bg-slate-900 text-white px-2 py-2 hover:bg-indigo-600 transition-colors">
                    Voir
                </a>

                <a href="{{ path('equipment_update', {id: equipment.id}) }}"
                    class="flex-1 text-center text-[9px] font-black uppercase tracking-widest border-2 border-slate-900 px-2 py-2 hover:bg-slate-900 hover:text-white transition-all">
                    Modifier
                </a>

          
                <a href="{{ path('stock_new', {'id': equipment.id}) }}"
                    class="flex-1 text-center text-[9px] font-black uppercase tracking-widest bg-emerald-500 text-white px-2 py-2 hover:bg-slate-900 transition-colors">
                    Stock
                </a>
                {% include "equipment/_delete_form.html.twig" %}
            </div>
        </div>
        {% else %}
        <div class="col-span-full py-16 text-center border-4 border-dashed border-slate-200 bg-slate-50">
            <p class="text-slate-400 font-black uppercase tracking-widest">Aucun équipement enregistré</p>
        </div>
        {% endfor %}
    </div>
</div>
{% endblock %}