{# templates/profile/edit.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Modifier mon profil{% endblock %}

{% block body %}
<div class="max-w-md mx-auto px-4 mt-10 pb-20">
    
   
    <a href="{{ path('home_index') }}" class="text-[10px] font-black uppercase tracking-widest text-slate-400 hover:text-slate-900 mb-6 block transition-colors">
        ← Retour au tableau de bord
    </a>


    <div class="mb-8">
        <h2 class="text-4xl font-black uppercase tracking-tighter text-slate-900 leading-none">
            Mon <span class="text-indigo-600">Profil</span>
        </h2>
        <p class="text-slate-500 text-xs font-bold uppercase mt-2">Modifiez vos informations personnelles</p>
    </div>


    <div class="bg-white border-4 border-slate-900 p-6 ">
        {{ form_start(formUser) }}
            <div class="space-y-6">
                
 
                <div>
                    <label class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-1">Prénom</label>
                    {{ form_widget(formUser.firstname, {
                        'attr': {
                            'class': 'w-full bg-slate-50 border-2 border-slate-900 p-3 text-sm font-black uppercase tracking-tight focus:ring-0 focus:border-indigo-600 focus:bg-white outline-none transition-all placeholder:text-slate-300'
                        }
                    }) }}
                    <div class="text-red-500 text-[10px] font-bold mt-1 uppercase">{{ form_errors(formUser.firstname) }}</div>
                </div>

                <div>
                    <label class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-1">Nom de famille</label>
                    {{ form_widget(formUser.name, {
                        'attr': {
                            'class': 'w-full bg-slate-50 border-2 border-slate-900 p-3 text-sm font-black uppercase tracking-tight focus:ring-0 focus:border-indigo-600 focus:bg-white outline-none transition-all placeholder:text-slate-300'
                        }
                    }) }}
                    <div class="text-red-500 text-[10px] font-bold mt-1 uppercase">{{ form_errors(formUser.name) }}</div>
                </div>

                <div>
                    <label class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-1">Adresse Email</label>
                    {{ form_widget(formUser.email, {
                        'attr': {
                            'class': 'w-full bg-slate-50 border-2 border-slate-900 p-3 text-sm font-black tracking-tight focus:ring-0 focus:border-indigo-600 focus:bg-white outline-none transition-all placeholder:text-slate-300'
                        }
                    }) }}
                    <div class="text-red-500 text-[10px] font-bold mt-1 uppercase">{{ form_errors(formUser.email) }}</div>
                </div>
                
                <div>
                    <label class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-1">Téléphone</label>
                    {{ form_widget(formUser.phone, {
                        'attr': {
                            'class': 'w-full bg-slate-50 border-2 border-slate-900 p-3 text-sm font-black tracking-tight focus:ring-0 focus:border-indigo-600 focus:bg-white outline-none transition-all placeholder:text-slate-300'
                        }
                    }) }}
                    <div class="text-red-500 text-[10px] font-bold mt-1 uppercase">{{ form_errors(formUser.phone) }}</div>
                </div>

                <div class="pt-4">
                    <button type="submit" class="w-full bg-slate-900 text-white font-black uppercase py-4 tracking-[0.2em] text-xs hover:bg-indigo-600 active:translate-x-1 active:translate-y-1 active:shadow-none transition-all shadow-[4px_4px_0px_0px_rgba(79,70,229,1)]">
                        Enregistrer les modifications
                    </button>
                </div>

            </div>
        {{ form_end(formUser) }}
    </div>


    <div class="mt-8 p-4 border-2 border-dashed border-slate-200 text-center">
        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">
            Pour modifier votre mot de passe, contactez l'administrateur du club.
        </p>
    </div>

</div>
{% endblock %}