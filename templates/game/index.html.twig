{% extends 'base.html.twig' %}

{% block title %}Les matchs{% endblock %}

{% block body %}
<div class="max-w-md mx-auto px-4 mt-6 pb-20">
    <div class="mb-10 text-center">
        <h2 class="text-4xl font-black uppercase tracking-tighter text-slate-900 leading-none">
            Les <span class="text-indigo-600">matchs</span>
        </h2>

        <div class="flex justify-center mt-6">
            <a href="{{ path('game_new') }}"
                class="bg-slate-900 text-white px-8 py-3 font-black uppercase text-xs tracking-widest active:bg-indigo-600 transition-colors">
                + Créer un match
            </a>
        </div>
    </div>

    <div class="space-y-4">
        {% for game in games %}
        <div class="bg-white border-4 border-slate-900 p-4 transition-transform relative ">
            
        
            <a href="{{ path('game_show', {'id': game.id}) }}" class="absolute inset-0 z-0"></a>

            <div class="relative z-10">
                <div class="flex justify-between items-start mb-2">
                    <span class="inline-block bg-indigo-600 text-white text-[10px] font-black px-2 py-0.5 uppercase mb-1">
                        {{ game.date ? game.date|date('d/m/y') : 'À programmer' }}
                    </span>

                 
                    {% if game.attendances|length > 0 %}
                        <span class="inline-block bg-emerald-100 text-emerald-700 text-[9px] font-bold px-2 py-0.5 uppercase border border-emerald-300">
                            ✓ Groupe fait
                        </span>
                    {% else %}
                        <span class="inline-block bg-amber-100 text-amber-700 text-[9px] font-bold px-2 py-0.5 uppercase border border-amber-300">
                            ! À convoquer
                        </span>
                    {% endif %}
                </div>

                <h3 class="text-xl font-black uppercase text-slate-900 tracking-tighter leading-tight">
                    {{ game.team.name }} <span class="text-indigo-600">VS</span> {{ game.opposingTeam }}
                </h3>
                <p class="text-slate-500 text-[10px] font-bold uppercase mt-1">
                    Lieu : {{ game.place }}
                </p>

                <div class="relative z-20 mt-4">
                    <a href="{{ path('attendance_take_mass', {'type': 'game', 'id': game.id}) }}" 
                       class="block text-center bg-slate-900 text-white py-2 text-[10px] font-black uppercase tracking-[0.2em] hover:bg-indigo-600 transition-colors border-2 border-slate-900">
                        Gérer les absences
                    </a>
                </div>

                <div class="relative z-20 flex border-t-2 border-slate-900 mt-4 pt-3 gap-4">
                    <a href="{{ path('game_update', {'id': game.id}) }}"
                        class="text-[10px] font-black uppercase tracking-widest text-slate-400 hover:text-indigo-600">Modifier</a>
                    <div class="text-[10px] font-black uppercase tracking-widest text-red-500">
                        {% include "game/_delete_form.html.twig" %}
                    </div>
                </div>
            </div>
        </div>
        {% else %}
            <p class="text-center text-slate-400 font-bold uppercase text-xs">Aucun match de prévu.</p>
        {% endfor %}
    </div>
</div>
{% endblock %}