{% extends 'base.html.twig' %}

{% block title %}Les matchs{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto px-4 mt-8 pb-20">

    <div class="mb-10">
        <h2 class="text-3xl font-black uppercase tracking-tighter text-slate-900 leading-none mb-4">
            Les <span class="text-indigo-600">matchs</span>
        </h2>
        
        <a href="{{ path('game_new') }}"
            class="inline-block bg-slate-900 text-white px-6 py-3 text-[10px] font-black uppercase tracking-widest border-2 border-slate-900 hover:bg-white hover:text-slate-900 transition-all">
            + Créer un match
        </a>
    </div>

 
    <div class="grid grid-cols-2 md:grid-cols-2 gap-6">
        {% for game in games %}
        <div class="bg-white border-4 border-slate-900 p-6 flex flex-col justify-between relative overflow-hidden group">
            <a href="{{ path('game_show', {id: game.id}) }}"</a>
          
            <span class="absolute top-0 left-0 bg-slate-900 text-white text-[9px] font-black px-3 py-1 uppercase tracking-tighter italic">
                {{ game.date ? game.date|date('d/m/Y') : 'À programmer' }}
            </span>

       
            <div class="mb-6 mt-6">
                <div class="flex items-center gap-2 mb-3">
                    {% if game.attendances|length > 0 %}
                        <span class="bg-emerald-500 text-white text-[8px] font-black px-2 py-0.5 uppercase">✓ Appel fait</span>
                    {% else %}
                        <span class="bg-amber-500 text-white text-[8px] font-black px-2 py-0.5 uppercase">! Appel à faire</span>
                    {% endif %}
                </div>

                <h3 class="text-2xl font-black uppercase leading-none mb-2">
                    {{ game.team.name }} <span class="text-indigo-600">VS</span> {{ game.opposingTeam }}
                </h3>
                
                <p class="text-slate-500 text-[10px] font-bold uppercase tracking-widest italic">
                    LIEU : {{ game.place|upper }}
                </p>
            </div>

        
            <div class="space-y-2">
           
                <a href="{{ path('attendance_take_mass', {'type': 'game', 'id': game.id}) }}" 
                   class="block text-center bg-emerald-500 text-white py-2 text-[10px] font-black uppercase tracking-widest border-2 border-slate-900 hover:bg-slate-900 transition-colors">
                   Gérer les absences
                </a>

                <div class="flex gap-2 border-t-2 border-slate-900 pt-3">

                    <a href="{{ path('game_update', {id: game.id}) }}"
                        class=" flex-1 text-center text-[9px] font-black uppercase tracking-widest border-2 border-slate-900 px-4 py-4 hover:bg-slate-900 hover:text-white transition-all">
                        Modifier
                    </a>
                  
                    {% include "game/_delete_form.html.twig" %}
                </div>
            </div>
        </div>
        {% else %}
        <div class="col-span-full py-16 text-center border-4 border-dashed border-slate-200 bg-slate-50">
            <p class="text-slate-400 font-black uppercase tracking-widest">Aucun match programmé</p>
        </div>
        {% endfor %}
    </div>
</div>
{% endblock %}