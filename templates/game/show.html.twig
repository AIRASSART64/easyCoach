{% extends 'base.html.twig' %}

{% block title %}Match vs {{ game.opposingTeam }}{% endblock %}

{% block body %}
<div class="max-w-xl mx-auto px-4 mt-6 pb-20">
    <a href="{{ path('game_index') }}" class="text-[10px] font-black uppercase tracking-widest text-slate-400 hover:text-slate-900 mb-6 block">
        ← Retour aux matchs
    </a>

    <div class="mb-8">
        <span class="inline-block bg-indigo-600 text-white text-xs font-black px-3 py-1 uppercase mb-2">
            {{ game.date ? game.date|date('d/m/Y') : 'Date à définir' }}
        </span>
        <h2 class="text-4xl font-black uppercase tracking-tighter text-slate-900 leading-none">
            {{ game.team.name }} <br>
            <span class="text-indigo-600 text-2xl">VS</span> {{ game.opposingTeam }}
        </h2>
    </div>

    <div class="space-y-6">
        
        <div class="bg-white border-4 border-slate-900 p-6 ">
            <h3 class="text-xs font-black uppercase text-slate-900 mb-4 tracking-widest">Le Groupe & Convocations</h3>
            
            <a href="{{ path('attendance_take_mass', {'type': 'game', 'id': game.id}) }}" 
               class="block w-full text-center bg-slate-900 text-white py-4 font-black uppercase tracking-widest text-sm hover:bg-indigo-600 transition-all">
               {% if game.attendances|length > 0 %}
                     Modifier le groupe sélectionné
               {% else %}
                     Sélectionner les joueurs convoqués
               {% endif %}
            </a>

         
            {% if game.attendances|length > 0 %}
                <div class="mt-6 border-t-2 border-slate-100 pt-4">
                    <p class="text-[10px] font-black uppercase text-slate-400 mb-2">Joueurs convoqués :</p>
                    <div class="flex flex-wrap gap-2">
                        {% for att in game.attendances %}
                            
                            {% if att.status.name|lower in ['convoqué', 'présent', 'titulaire', 'remplaçant'] %}
                                <span class="bg-slate-100 border border-slate-900 px-2 py-1 text-[10px] font-bold uppercase">
                                    {{ att.player.name }}
                                </span>
                            {% endif %}
                        {% endfor %}
                    </div>
                </div>
            {% endif %}
        </div>

        
        <div class="bg-white border-2 border-slate-900 p-6">
            <h3 class="text-xs font-black uppercase text-slate-400 mb-4 tracking-widest">Détails Techniques</h3>
            
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <span class="block text-[10px] font-bold uppercase text-slate-500">Lieu :</span>
                    <span class="text-sm font-black uppercase">{{ game.place }}</span>
                </div>
                <div>
                    <span class="block text-[10px] font-bold uppercase text-slate-500">Score Final :</span>
                    <span class="text-sm font-black">{{ game.scoreHome|default('?') }} - {{ game.scoreAway|default('?') }}</span>
                </div>
            </div>

            {% if game.coachObservation %}
                <div class="mt-4 pt-4 border-t border-slate-100">
                    <span class="block text-[10px] font-bold uppercase text-slate-500">Bilan du coach :</span>
                    <p class="text-sm italic text-slate-700 mt-1">{{ game.coachObservation }}</p>
                </div>
            {% endif %}
        </div>

        <div class="grid grid-cols-2 gap-4">
            <a href="{{ path('game_update', {'id': game.id}) }}" class="bg-white text-slate-900 text-center py-4 border-2 border-slate-900 font-black uppercase text-sm hover:bg-slate-50 transition-all">
                Modifier le match
            </a>
            <div class="flex">
                {% include "game/_delete_form.html.twig" %}
            </div>
        </div>
    </div>
</div>
{% endblock %}