<form method="post" action="{{ path('game_delete', {'id': game.id}) }}"
   onsubmit="return confirm('Confirmez-vous la suppression définitive du match');" 
    class="flex items-center">
    
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ game.id) }}">
    
 <button type="submit" 
            class="flex-1 text-[9px] text-center px-4 py-4 border-2 border-slate-900 bg-red-500 font-black uppercase tracking-widest text-white hover:bg-red-500 hover:text-white active:scale-95 transition-all">
        Supprimer
    </button>
</form>