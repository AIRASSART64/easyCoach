<form method="post" action="{{ path('game_delete', {'id': game.id}) }}"
   onsubmit="return confirm('Confirmez-vous la suppression définitive du match');" 
    class="flex items-center">
    
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ game.id) }}">
    
   <button type="submit" 
            class="text-[10px] font-black uppercase tracking-widest bg-red-500 text-white px-2 py-3 hover:text-white active:scale-95 transition-all">
        Supprimer
    </button>
</form>