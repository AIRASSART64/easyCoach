{% extends 'base.html.twig' %}

{% block title %}Inscription Coach - easyCoach{% endblock %}

{% block body %}
<div class="max-w-xl mx-auto mt-6 pb-10 px-4">
    <div class="bg-white border-2 border-slate-900 p-8 rounded-none">
        <h1 class="text-2xl font-black uppercase mb-8 tracking-tight text-center">Nouveau Coach</h1>

        {{ form_start(registrationForm, {'attr': {'class': 'space-y-6'}}) }}
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    {{ form_label(registrationForm.firstname, 'Prénom', {'label_attr': {'class': 'text-xs font-black uppercase text-slate-500 mb-2 block'}}) }}
                    {{ form_widget(registrationForm.firstname, {'attr': {'class': 'w-full h-12 px-4 border-2 border-slate-900 rounded-none font-medium focus:border-emerald-600 outline-none'}}) }}
                </div>
                <div>
                    {{ form_label(registrationForm.name, 'Nom', {'label_attr': {'class': 'text-xs font-black uppercase text-slate-500 mb-2 block'}}) }}
                    {{ form_widget(registrationForm.name, {'attr': {'class': 'w-full h-12 px-4 border-2 border-slate-900 rounded-none font-medium focus:border-emerald-600 outline-none'}}) }}
                </div>
            </div>

            <div>
                {{ form_label(registrationForm.email, 'Email', {'label_attr': {'class': 'text-xs font-black uppercase text-slate-500 mb-2 block'}}) }}
                {{ form_widget(registrationForm.email, {'attr': {'class': 'w-full h-12 px-4 border-2 border-slate-900 rounded-none font-medium focus:border-emerald-600 outline-none'}}) }}
            </div>

            <div>
                {{ form_label(registrationForm.phone, 'Téléphone', {'label_attr': {'class': 'text-xs font-black uppercase text-slate-500 mb-2 block'}}) }}
                {{ form_widget(registrationForm.phone, {'attr': {'class': 'w-full h-12 px-4 border-2 border-slate-900 rounded-none font-medium focus:border-emerald-600 outline-none'}}) }}
            </div>

            <div>
                {{ form_label(registrationForm.plainPassword, 'Mot de passe', {'label_attr': {'class': 'text-xs font-black uppercase text-slate-500 mb-2 block'}}) }}
                {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'w-full h-12 px-4 border-2 border-slate-900 rounded-none font-medium focus:border-emerald-600 outline-none'}}) }}
            </div>

            <div class="flex items-center gap-3 pt-4">
                {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'w-6 h-6 border-2 border-slate-900 rounded-none accent-slate-900'}}) }}
                {{ form_label(registrationForm.agreeTerms, "J'accepte les conditions", {'label_attr': {'class': 'text-sm font-bold text-slate-700'}}) }}
            </div>

            <button type="submit" class="w-full mt-4 bg-emerald-600 text-white text-lg font-bold py-4 border-2 border-emerald-600 rounded-none hover:bg-emerald-700 hover:border-emerald-700 transition-all uppercase">
                Créer mon compte
            </button>
        {{ form_end(registrationForm) }}
    </div>
</div>
{% endblock %}
