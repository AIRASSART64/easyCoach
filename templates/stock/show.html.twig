{% extends 'base.html.twig' %}

{% block title %}Détail du stock {% endblock %}

{% block body %}
<div class="max-w-xl mx-auto px-4 mt-6 pb-20">
 
    <div class="mb-8">
        <h2 class="text-3xl font-black uppercase tracking-tighter text-slate-900 leading-none">
             Détail du stock
        </h2>

    </div>

    <div class="space-y-6">
    
        <div class="bg-white border-2 border-slate-900 p-6">
            <h3 class="text-xs font-black uppercase text-slate-400 mb-4 tracking-widest">Informations sur le stock </h3>
            
            <div class="space-y-4">
          
                <div class="flex justify-between items-center pt-2 border-t border-slate-100">
                    <div>
                        <span class="block text-xs font-bold uppercase text-slate-500"> Date : <span class="text-lg font-bold">{{stock.date|date('d/m/Y') }}</span></span>
    
                    </div>
                </div>
                 <div class="pt-2 border-t border-slate-100">
                    <span class="block text-xs font-bold uppercase text-slate-500"> Equipement concerné :  <span class="text-lg font-bold break-all">{{stock.equipment.name}}</span> </span>
                    
                </div>
        
                <div class="flex justify-between items-center pt-2 border-t border-slate-100">
                    <div>
                        <span class="block text-xs font-bold uppercase text-slate-500"> Quantité :  <span class="text-lg font-bold"> {{stock.quantity }}</span></span>
                        
                    </div>
                </div>
                <div class="pt-2 border-t border-slate-100">
                    <span class="block text-xs font-bold uppercase text-slate-500"> Type :<span class="text-lg font-bold break-all"> {{stock.type.value}}</span> </span>
                    
                </div>
             
        

                {% if stock.reason %}
                <div class="pt-2 border-t border-slate-100">
                    <span class="block text-xs font-bold uppercase text-slate-500">Commentaires</span>
                    <p class="text-xs font-bold break-all">{{ stock.reason }}</p>
                </div>
                {% endif %}

            </div>
        </div>

        <div class="grid grid-cols-2 gap-4 mt-8">
            <a href="{{ path('stock_update', {'id': stock.id}) }}" class="bg-white text-slate-900 text-center py-4 border-2 border-slate-900 font-black uppercase text-sm hover:bg-slate-50 transition-all">
                Modifier
            </a>
            <a href="{{ path('stock_index') }}" class="bg-slate-900 text-white text-center py-4 border-2 border-slate-900 font-black uppercase text-sm hover:bg-indigo-600 transition-all">
                Retour
            </a>
        </div>
    </div>
</div>
{% endblock %}