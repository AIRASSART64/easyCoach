{% extends 'base.html.twig' %}

{% block body %}
<div class="max-w-xl mx-auto px-4 mt-6 pb-12">
    
    <h2 class="text-2xl font-black uppercase tracking-tight mb-8 text-slate-900">
        Modifier un statut 
    </h2>


    <div class="bg-white border-2 border-slate-900 p-6 md:p-8">
        {{ form_start(formStatus, {'attr': {'class': 'space-y-6'}}) }}
            
            
            <div class="form-container">
                {{ form_widget(formStatus) }}
            </div>

            <button type="submit" class="w-full bg-slate-900 text-white text-lg font-bold py-4 border-2 border-slate-900 hover:bg-indigo-600 hover:border-indigo-600 transition-all uppercase">
                Enregistrer le statut
            </button>
            
        {{ form_end(formStatus )}}
       
    </div>

  
    <div class="mt-6">
        <a href="{{ path('status_index') }}" class="block w-full text-center bg-white text-slate-900 text-sm font-black py-4 border-2 border-slate-900 hover:bg-slate-50 transition-all uppercase">
            ← Toutes les status
        </a>
    </div>
</div>
{% endblock %}