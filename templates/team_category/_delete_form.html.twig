<form method="post" action="{{ path('team_category_delete', {'id': team_category.id}) }}" onsubmit="return confirm('Confirmez-vous la suppression de cette catégorie?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ team_category.id) }}">
    <button class="btn">Supprimer</button>
</form>
