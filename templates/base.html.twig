<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}easyCoach{% endblock %}</title>
    <link rel="icon"
        href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚡</text></svg>">

    <script src="https://cdn.tailwindcss.com"></script>

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap');

        body {
            font-family: 'Inter', sans-serif;
        }

        input:focus,
        select:focus,
        textarea:focus {
            outline: 4px solid #4f46e5 !important;
            outline-offset: 2px;
        }

        label {
            font-weight: 900 !important;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #0f172a;
            margin-bottom: 0.5rem;
            display: block;
        }

        .form-container input,
        .form-container select,
        .form-container textarea {
            width: 100%;
            height: 3rem;
            padding: 0 1rem;
            margin-top: 0.5rem;
            margin-bottom: 1.5rem;
            border: 2px solid #0f172a;
            border-radius: 0;
            font-weight: 500;
            font-size: 1.125rem;
            outline: none;
            transition: border-color 0.2s;
        }

        .form-container input:focus {
            border-color: #4f46e5;
        }


        .form-container label {
            display: block;
            font-size: 0.75rem;
            font-weight: 900;
            text-transform: uppercase;
            color: #64748b;
            letter-spacing: 0.05em;
        }

        .form-container ul {
            list-style: none;
            padding: 0;
            margin: -1rem 0 1.5rem 0;
            color: #dc2626;
            font-weight: 700;
            font-size: 0.875rem;
        }

        @media screen and (max-width: 768px) {

            input,
            select,
            textarea {
                font-size: 16px !important;
            }
        }

    
        .btn-mobile {
            @apply w-full py-5 text-lg font-black uppercase border-4 border-slate-900 transition-all active:scale-95;
        }

        .form-container input:active,
        .form-container select:active {
            background-color: #f8fafc;
        }
        main {
            -webkit-overflow-scrolling: touch;
        }
    </style>
</head>

<body class="bg-white text-slate-950 antialiased min-h-screen flex flex-col">

    {# --- HEADER / NAVIGATION --- #}
    <nav class="bg-slate-950 text-white sticky top-0 z-50 border-b-4 border-indigo-600">
        <div class="max-w-7xl mx-auto px-4 h-20 flex justify-between items-center">
            
            {# LOGO #}
            <a href="{{ path('home_index') }}" class="text-2xl font-black tracking-tighter italic hover:text-indigo-400 transition-colors">
                EASY<span class="text-indigo-500">COACH</span>
            </a>

            <div class="flex items-center gap-4">
                {% if app.user %}
                    {# CONNECTÉ : Prénom + Menu #}
                    <div class="hidden md:block bg-indigo-600 px-4 py-2 border-2 border-white font-black text-xs uppercase italic">
                        Coach {{ app.user.firstname }}
                    </div>
                     <a href="{{ path('app_logout') }}" class="px-4 py-2 bg-slate-600 text-white text-xs uppercase italic border-2 border-white hover:bg-red-700 transition-colors">Déconnexion</a>
                    <button onclick="toggleMenu()" class="p-3 bg-white text-slate-950 border-2 border-slate-950 hover:bg-indigo-600 hover:text-white transition-all">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M4 6h16M4 12h16m-7 6h7"></path>
                        </svg>
                    </button>
                {% else %}
                    {# NON CONNECTÉ : Actions rapides #}
                    <div class="flex gap-2">
                        <a href="{{ path('app_login') }}" class="text-[10px] font-black uppercase tracking-widest border-2 border-white px-4 py-2 hover:bg-white hover:text-slate-950 transition-all">Connexion</a>
                        <a href="{{ path('app_register') }}" class="text-[10px] font-black uppercase tracking-widest bg-indigo-600 border-2 border-indigo-600 px-4 py-2 hover:bg-transparent transition-all">S'inscrire</a>
                    </div>
                {% endif %}
            </div>
        </div>

        {# --- MENU MOBILE / NAV FONCTIONNELLE --- #}
        {% if app.user %}
        <div id="mobile-menu" class="hidden bg-slate-900 border-b-4 border-slate-950">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 font-black uppercase text-sm tracking-widest">
                <a href="{{ path('home_index') }}" class="p-6 border-b border-slate-800 hover:bg-indigo-600 transition-colors">Tableau de bord</a>
                <a href="{{ path('player_index') }}" class="p-6 border-b border-slate-800 hover:bg-indigo-600 transition-colors">Effectif</a>
                <a href="{{ path('training_index') }}" class="p-6 border-b border-slate-800 hover:bg-indigo-600 transition-colors">Entraînements</a>
                <a href="{{ path('equipment_index') }}" class="p-6 border-b border-slate-800 hover:bg-indigo-600 transition-colors">Équipements</a>
               
            </div>
        </div>
        {% endif %}
    </nav>

    {# --- CONTENU PRINCIPAL --- #}
    <main class="flex-grow">
        {% block body %}{% endblock %}
    </main>

    {# --- FOOTER SIMPLE --- #}
    <footer class="bg-slate-950 text-white border-t-8 border-indigo-600 py-10">
        <div class="max-w-7xl mx-auto px-4 flex flex-col items-center gap-4">
            <div class="text-xl font-black italic tracking-tighter">EASYCOACH</div>
            <div class="h-1 w-12 bg-indigo-600"></div>
            <p class="text-slate-500 text-[10px] font-bold uppercase tracking-[0.3em]">
                &copy; {{ "now"|date("Y") }} - Gestion Sportive Brutaliste
            </p>
        </div>
    </footer>

    <script>
        function toggleMenu() {
            const menu = document.getElementById('mobile-menu');
            menu.classList.toggle('hidden');
        }
    </script>
</body>

</html>