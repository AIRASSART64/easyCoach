<form method="post" action="{{ path('team_delete', {'id': team.id}) }}"
    onsubmit="return confirm(`Confirmez-vous la suppression  définitive de l'équipe {{team.name}} ?`);" class="flex-1 md:flex-none">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ team.id) }}">
    <button class="w-full h-full bg-red-600 border-2 border-slate-900 p-3 text-white hover:bg-red-700 transition-colors"
        title="Supprimer">
        🗑️
    </button>
</form>