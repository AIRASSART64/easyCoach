{% extends 'base.html.twig' %}

{% block title %}Mes Équipes{% endblock %}

{% block body %}
<div class="max-w-md mx-auto px-4 mt-8 pb-20">

   
    <div class="mb-10 text-center">
        <h2 class="text-3xl font-black uppercase tracking-tighter text-slate-900 leading-none mb-8">
            Les <span class="text-indigo-600">équipes</span>
        </h2>

        <div class="grid grid-cols-1 gap-4">
            <a href="{{ path('team_new') }}"
                class="bg-indigo-600 text-white px-8 py-4 font-black uppercase text-sm tracking-widest  active:shadow-none active:translate-x-1 active:translate-y-1 transition-all">
                + Nouvelle Équipe
            </a>
            
            <a href="{{ path('team_category_new') }}"
                class="bg-yellow-400 text-slate-900 px-8 py-3 font-black uppercase text-[10px] tracking-widest  active:shadow-none active:translate-x-1 active:translate-y-1 transition-all">
                Gérer les catégories
            </a>
        </div>
    </div>

    <div class="space-y-4">
        {% for team in teams %}
        <div class="bg-white border-4 border-slate-900 p-4 transition-transform relative ">
            
        
            <a href="{{ path('team_show', {'id': team.id}) }}" class="absolute inset-0 z-0"></a>

            <div class="relative z-10">
                <div class="flex justify-between items-start mb-2">
                    <span class="inline-block bg-indigo-600 text-white text-[10px] font-black px-2 py-0.5 uppercase mb-1">
                        {{ team.category.name|default('Général') }}
                    </span>
                </div>

                <h3 class="text-xl font-black uppercase text-slate-900 tracking-tighter leading-tight">
                    {{ team.name }}
                </h3>
                <p class="text-slate-500 text-[10px] font-bold uppercase mt-1">
                    {{ team.player|length }} Joueurs
                </p>

                <div class="relative z-20 mt-4">
                    <a href="{{ path('team_player', {'id': team.id}) }}"
                       class="block text-center bg-slate-900 text-white py-2 text-[10px] font-black uppercase tracking-[0.2em] hover:bg-indigo-600 transition-colors border-2 border-slate-900">
                        Gérer l'effectif
                    </a>
                </div>

                <div class="relative z-20 flex border-t-2 border-slate-900 mt-4 pt-3 gap-4">
                    <a href="{{ path('team_update', {'id': team.id}) }}"
                        class="text-[10px] font-black uppercase tracking-widest text-slate-400 hover:text-indigo-600">Modifier</a>
                    <div class="text-[10px] font-black uppercase tracking-widest text-red-500">
                        {% include "team/_delete_form.html.twig" %}
                    </div>
                </div>
            </div>
        </div>
        {% else %}
            <p class="text-center text-slate-400 font-bold uppercase text-xs">Aucune équipe enregistrée.</p>
        {% endfor %}
    </div>

</div>
{% endblock %}