{% extends 'base.html.twig' %}

{% block title %}Mes Équipes{% endblock %}

{% block body %}
<div class="max-w-md mx-auto px-4 mt-8 pb-20">

    {# --- HEADER & ACTIONS --- #}
    <div class="mb-12 text-center">
        <h1 class="text-5xl font-black uppercase tracking-tighter text-slate-900 leading-none mb-8">
            Mes <span class="text-indigo-600">équipes</span>
        </h1>

        <div class="grid grid-cols-1 gap-3">
            {# Bouton Principal : Créer équipe #}
            <a href="{{ path('team_new') }}"
                class="bg-slate-900 text-white px-8 py-4 font-black uppercase text-sm tracking-widest  active:shadow-none active:translate-x-1 active:translate-y-1 transition-all">
                + Nouvelle Équipe
            </a>
            
            {# Bouton Secondaire : Catégories #}
            <a href="{{ path('team_category_new') }}"
                class="bg-white text-slate-900 border-4 border-slate-900 px-8 py-3 font-black uppercase text-[10px] tracking-widest hover:bg-slate-50 transition-colors">
                Gérer les catégories
            </a>
        </div>
    </div>

    {# --- LISTE DES ÉQUIPES --- #}
    <div class="space-y-6">
        {% for team in teams %}
        <div class="bg-white border-4 border-slate-900 p-5 shadow-[8px_8px_0px_0px_rgba(15,23,42,1)] relative overflow-hidden">
            
            <div class="flex justify-between items-start mb-4">
                <div class="cursor-pointer flex-grow" 
                     data-url="{{ path('team_show', {'id': team.id}) }}"
                     onclick="window.location.href=this.dataset.url">
                    
                    {# Badge Catégorie #}
                    <span class="inline-block bg-indigo-600 text-white text-[10px] font-black px-2 py-1 uppercase mb-2 border-2 border-slate-900 shadow-[2px_2px_0px_0px_rgba(15,23,42,1)]">
                        {{ team.category.name|default('Sans catégorie') }}
                    </span>

                    <h2 class="text-3xl font-black uppercase text-slate-900 tracking-tighter leading-none mb-1">
                        {{ team.name }}
                    </h2>
                    
                    <p class="text-slate-500 text-xs font-black uppercase tracking-tight">
                        {{ team.player|length }} Joueurs inscrits
                    </p>
                </div>

                {# Action rapide : Ajouter un joueur à cette équipe #}
                <a href="{{ path('team_player', {'id': team.id}) }}"
                    class="bg-yellow-400 border-4 border-slate-900 p-3 shadow-[4px_4px_0px_0px_rgba(15,23,42,1)] active:shadow-none active:translate-x-1 active:translate-y-1 transition-all"
                    title="Ajouter un joueur">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                    </svg>
                </a>
            </div>

            {# --- FOOTER CARD ACTIONS --- #}
            <div class="flex items-center border-t-4 border-slate-900 mt-4 pt-4 gap-6">
                <a href="{{ path('team_update', {'id': team.id}) }}"
                    class="text-xs font-black uppercase tracking-widest text-slate-900 hover:text-indigo-600 underline decoration-4 underline-offset-4 decoration-indigo-600">
                    Modifier
                </a>
                
                <div class="ml-auto">
                    {# On garde le formulaire de suppression tel quel mais intégré proprement #}
                    {% include "team/_delete_form.html.twig" %}
                </div>
            </div>
        </div>
        {% else %}
            <div class="text-center py-10 border-4 border-dashed border-slate-300">
                <p class="font-black uppercase text-slate-400 tracking-widest text-sm">Aucune équipe pour le moment</p>
            </div>
        {% endfor %}
    </div>

</div>
{% endblock %}