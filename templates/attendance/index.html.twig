{% extends 'base.html.twig' %}

{% block title %}Gestion des absences{% endblock %}

{% block body %}

<div class="max-w-md mx-auto px-4 mt-6 pb-20">


    <div class="mb-10 text-center">
        <h2 class="text-3xl font-black uppercase tracking-tighter text-slate-900 leading-none">
            Gestion <span class="text-indigo-600">des absences </span>
        </h2>

        <div class="flex justify-center mt-6">
            <a href="{{ path('attendance_new') }}"
                class="bg-slate-900 text-white px-8 py-3 font-black uppercase text-xs tracking-widest active:bg-indigo-600 transition-colors">
                + Créer une absence
            </a>
        </div>
    </div>


    <div class="space-y-4">
        {% for attendance in attendances %}
        <div
            class="bg-white border-4 border-slate-900  p-4 transition-transform active:translate-x-1 active:translate-y-1 active:shadow-none">

            <div class="flex justify-between items-start mb-4 active:translate-x-0.5 active:translate-y-0.5">
                <div class="cursor-pointer" data-url="{{ path('attendance_show', {'id': attendance.id}) }}"
                    onclick="window.location.href=this.dataset.url">
                    <span
                        class="inline-block bg-indigo-600 text-white text-[10px] font-black px-2 py-0.5 uppercase mb-1">
                        {% if attendance.startDate|date('d/m/y') %}
                        Date de début de l'absence : {{ attendance.startDate|date('d/m/y') }}

                        {% endif %}
                    </span>
                    <span
                        class="inline-block bg-indigo-600 text-white text-[10px] font-black px-2 py-0.5 uppercase mb-1">
                        {% if attendance.endDate|date('d/m/y') %}
                        Date de fin de l'absence : {{ attendance.endDate|date('d/m/y') }}

                        {% endif %}
                    </span>
                    <h3 class="text-2xl font-black uppercase text-slate-900 tracking-tighter">
                        Statut : {{ attendance.status.name }}
                    </h3>
                       <span
                        class="inline-block bg-indigo-600 text-white text-[10px] font-black px-2 py-0.5 uppercase mb-1">
                        {% if attendance.justificationDate|date('d/m/y') %}
                        Date de la communication du justificatif : {{ attendance.justificationDate|date('d/m/y') }}

                        {% endif %}
                    </span>
                    
                    <p class="text-slate-500 text-xs font-bold uppercase">
                        Commentaires : {{ attendance.coachObservation }}
                    </p>
                    <p class="text-slate-500 text-xs font-bold uppercase">
                       
                    </p>

                </div>
            </div>


            <div class="flex border-t-2 border-slate-900 mt-4 pt-3 gap-4">
                <a href="{{ path('attendance_update', {'id': attendance.id}) }}"
                    class="text-[10px] font-black uppercase tracking-widest text-slate-400 hover:text-indigo-600">Modifier</a>
                <div class="text-[10px] font-black uppercase tracking-widest text-red-500">
                    {% include "attendance/_delete_form.html.twig" %}
                </div>
            </div>
        </div>
        {% endfor %}
    </div>

</div>
{% endblock %}